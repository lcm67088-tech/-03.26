# =====================================
# Backend 환경변수
# =====================================

# 데이터베이스
DATABASE_URL=postgresql://nplace:nplace1234@localhost:5432/nplace

# Redis
REDIS_URL=redis://localhost:6379

# JWT 보안 키 (프로덕션에서는 반드시 변경! 최소 32자 이상의 무작위 문자열)
# 생성 예: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS 허용 오리진
CORS_ORIGINS=["http://localhost:3000"]

# 환경 설정
ENVIRONMENT=development
DEBUG=true

# =====================================
# Frontend 환경변수
# =====================================

# API 서버 URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# =====================================
# 선택적 환경변수 (Sprint 2+ 에서 사용)
# =====================================

# 소셜 로그인
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 이메일 발송 (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# 카카오 알림톡
KAKAO_CHANNEL_ID=
KAKAO_PLUS_FRIEND_KEY=

# PG 결제
KAKAOPAY_ADMIN_KEY=
NAVERPAY_CLIENT_ID=
NAVERPAY_CLIENT_SECRET=

# AWS S3 (이미지 세탁용)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=nplace-images

# Slack (운영 알림)
SLACK_WEBHOOK_URL=
